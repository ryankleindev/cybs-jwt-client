# Copy this to `.env` and fill in your values. `.env` is gitignored.

# Sandbox host. Production is api.cybersource.com
CYBS_RUN_ENVIRONMENT=apitest.cybersource.com

# Your merchant id (MID).
CYBS_MERCHANT_ID=your_mid

# Meta key (portfolio-based) auth. Set true if you authenticate with a portfolio id.
CYBS_USE_META_KEY=true
CYBS_PORTFOLIO_ID=your_portfolio_id

# Request p12 — holds your signing key AND the Cybersource request-MLE cert.
CYBS_REQUEST_P12_PATH=keys/rk_cp_sandbox_request.p12
CYBS_REQUEST_P12_PASSWORD=your_request_p12_password

# Response p12 — holds your response-MLE private key. Only needed for response MLE.
CYBS_RESPONSE_P12_PATH=keys/rk_cp_sandbox_response.p12
CYBS_RESPONSE_P12_PASSWORD=your_response_p12_password

# Per-run MLE mode for the example: none | request | response | both
CYBS_MLE=none
