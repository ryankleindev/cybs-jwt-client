{
  "name": "@ryankleindev/cybs-jwt-client",
  "version": "0.1.0",
  "description": "A small, transparent toolkit for Cybersource REST API JWT authentication (standard + meta key) with per-call Message-Level Encryption — built to be read and debugged, not to be another heavyweight SDK.",
  "main": "src/index.js",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "example": "node examples/payment.js"
  },
  "keywords": [
    "cybersource",
    "jwt",
    "authentication",
    "mle",
    "message-level-encryption",
    "payments",
    "rest"
  ],
  "author": "Ryan Klein",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryankleindev/cybs-jwt-client.git",
    "directory": "node"
  },
  "bugs": {
    "url": "https://github.com/ryankleindev/cybs-jwt-client/issues"
  },
  "homepage": "https://github.com/ryankleindev/cybs-jwt-client#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "jose": "^5.9.6",
    "node-forge": "^1.3.1"
  }
}
